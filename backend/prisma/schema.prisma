generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum PaymentMethod {
  cash
  qr
}

enum PaymentStatus {
  pending
  paid
  cancelled
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(100)
  icon      String?   @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  products  Product[]

  @@map("categories")
}

model Supplier {
  id         String      @id @default(uuid()) @db.Uuid
  name       String      @unique @db.VarChar(200)
  phone      String?     @db.VarChar(20)
  note       String?
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  importLogs ImportLog[]

  @@map("suppliers")
}

model Product {
  id                String             @id @default(uuid()) @db.Uuid
  categoryId        String?            @map("category_id") @db.Uuid
  name              String             @db.VarChar(300)
  sku               String             @unique @db.VarChar(50)
  unit              String             @db.VarChar(30)
  retailPrice       Decimal            @map("retail_price") @db.Decimal(12, 0)
  stockQuantity     Int                @default(0) @map("stock_quantity")
  lowStockThreshold Int                @default(5) @map("low_stock_threshold")
  technicalSpecs    String?            @map("technical_specs")
  imageUrl          String?            @map("image_url") @db.VarChar(500)
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamp(6)
  category          Category?          @relation(fields: [categoryId], references: [id])
  embedding         ProductEmbedding?
  importLogs        ImportLog[]
  orderItems        OrderItem[]
  returnItems       ReturnItem[]

  @@index([categoryId], map: "idx_products_category")
  @@map("products")
}

model ProductEmbedding {
  id          String                    @id @default(uuid()) @db.Uuid
  productId   String                    @unique @map("product_id") @db.Uuid
  imageVector Unsupported("vector(768)")? @map("image_vector")
  textVector  Unsupported("vector(768)")? @map("text_vector")
  updatedAt   DateTime                  @updatedAt @map("updated_at") @db.Timestamp(6)
  product     Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_embeddings")
}

model ImportLog {
  id          String    @id @default(uuid()) @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  supplierId  String?   @map("supplier_id") @db.Uuid
  importPrice Decimal   @map("import_price") @db.Decimal(12, 0)
  quantity    Int
  note        String?
  importDate  DateTime  @map("import_date") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  product     Product   @relation(fields: [productId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  @@index([productId, importDate], map: "idx_import_product_date")
  @@index([supplierId], map: "idx_import_supplier")
  @@map("import_logs")
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 0)
  paidAmount    Decimal?      @map("paid_amount") @db.Decimal(12, 0)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @map("payment_status")
  note          String?
  orderDate     DateTime      @map("order_date") @db.Timestamp(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  items         OrderItem[]
  returns       Return[]

  @@index([orderDate], map: "idx_orders_date")
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 0)
  subtotal  Decimal @db.Decimal(12, 0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId], map: "idx_order_items_order")
  @@index([productId], map: "idx_order_items_product")
  @@map("order_items")
}

model Return {
  id           String       @id @default(uuid()) @db.Uuid
  orderId      String       @map("order_id") @db.Uuid
  reason       String?
  refundAmount Decimal?     @map("refund_amount") @db.Decimal(12, 0)
  returnDate   DateTime     @map("return_date") @db.Timestamp(6)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  order        Order        @relation(fields: [orderId], references: [id])
  items        ReturnItem[]

  @@index([orderId], map: "idx_returns_order")
  @@map("returns")
}

model ReturnItem {
  id        String  @id @default(uuid()) @db.Uuid
  returnId  String  @map("return_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 0)
  return    Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([returnId], map: "idx_return_items_return")
  @@index([productId], map: "idx_return_items_product")
  @@map("return_items")
}

model StoreSetting {
  id                       String   @id @default(uuid()) @db.Uuid
  storeName                String   @default("Cửa hàng Vật tư Gia đình") @map("store_name") @db.VarChar(200)
  bankName                 String?  @map("bank_name") @db.VarChar(100)
  bankAccount              String?  @map("bank_account") @db.VarChar(50)
  accountHolderName        String?  @map("account_holder_name") @db.VarChar(200)
  defaultLowStockThreshold Int      @default(5) @map("default_low_stock_threshold")
  logoUrl                  String?  @map("logo_url") @db.VarChar(500)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("store_settings")
}
